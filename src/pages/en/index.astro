---
import Layout from '../../layouts/Layout.astro';
import { useTranslations, localizePath } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={t('nav.home')} description={t('site.tagline')}>
  <section class="max-w-7xl mx-auto px-6 pt-24 pb-32 md:pt-40 md:pb-48">
    <div class="max-w-3xl">
      <p class="text-xs uppercase tracking-[0.3em] text-neutral-400 mb-6">
        {t('site.tagline')}
      </p>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-light tracking-tight leading-[1.05] mb-10">
        {t('home.hero.title')}
      </h1>
      <p class="text-lg md:text-xl text-neutral-600 max-w-xl leading-relaxed mb-12">
        {t('home.hero.subtitle')}
      </p>
      <a
        href={localizePath('/gallery', lang)}
        class="inline-block text-sm uppercase tracking-[0.25em] border-b border-black pb-1 hover:opacity-60 transition-opacity"
      >
        {t('home.cta.gallery')} →
      </a>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 pb-32">
    <div class="flex items-end justify-between mb-12">
      <h2 class="text-2xl md:text-3xl font-light tracking-tight">
        {t('home.featured')}
      </h2>
      <a
        href={localizePath('/gallery', lang)}
        class="text-xs uppercase tracking-[0.25em] text-neutral-500 hover:text-black transition-colors"
      >
        {t('home.viewAll')} →
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {[1, 2, 3].map((i) => (
        <div class="aspect-[4/5] bg-neutral-100 hover:bg-neutral-200 transition-colors duration-500 flex items-center justify-center">
          <span class="text-xs uppercase tracking-[0.25em] text-neutral-400">Soon {i}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
