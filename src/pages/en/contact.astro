---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<Layout title={t('contact.title')}>
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-32">
    <p class="text-xs uppercase tracking-[0.3em] text-neutral-400 mb-4">
      AldeArts
    </p>
    <h1 class="text-5xl md:text-6xl font-light tracking-tight mb-8">
      {t('contact.title')}
    </h1>
    <p class="text-lg text-neutral-600 max-w-xl leading-relaxed mb-16">
      {t('contact.subtitle')}
    </p>

    <div class="mb-16">
      <p class="text-xs uppercase tracking-[0.25em] text-neutral-400 mb-2">
        {t('contact.email.label')}
      </p>
      <a href="mailto:info@aldearts.com" class="text-2xl font-light border-b border-black pb-1 hover:opacity-60 transition-opacity">
        info@aldearts.com
      </a>
    </div>

    <form class="space-y-8" name="contact" method="POST" data-netlify="true">
      <div>
        <label for="name" class="block text-xs uppercase tracking-[0.25em] text-neutral-500 mb-2">
          {t('contact.form.name')}
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full border-b border-neutral-200 focus:border-black bg-transparent py-3 outline-none transition-colors"
        />
      </div>

      <div>
        <label for="email" class="block text-xs uppercase tracking-[0.25em] text-neutral-500 mb-2">
          {t('contact.form.email')}
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full border-b border-neutral-200 focus:border-black bg-transparent py-3 outline-none transition-colors"
        />
      </div>

      <div>
        <label for="subject" class="block text-xs uppercase tracking-[0.25em] text-neutral-500 mb-2">
          {t('contact.form.subject')}
        </label>
        <input
          type="text"
          id="subject"
          name="subject"
          class="w-full border-b border-neutral-200 focus:border-black bg-transparent py-3 outline-none transition-colors"
        />
      </div>

      <div>
        <label for="message" class="block text-xs uppercase tracking-[0.25em] text-neutral-500 mb-2">
          {t('contact.form.message')}
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full border-b border-neutral-200 focus:border-black bg-transparent py-3 outline-none transition-colors resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="text-xs uppercase tracking-[0.3em] border border-black px-8 py-4 hover:bg-black hover:text-white transition-colors"
      >
        {t('contact.form.submit')} →
      </button>
    </form>
  </section>
</Layout>
