---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'tr';
const t = useTranslations(lang);

const categories = [
  { key: 'category.painting' as const, slug: 'painting' },
  { key: 'category.digital' as const, slug: 'digital' },
  { key: 'category.illustration' as const, slug: 'illustration' },
  { key: 'category.sculpture' as const, slug: 'sculpture' },
  { key: 'category.mixed' as const, slug: 'mixed' },
];
---

<Layout title={t('gallery.title')} description={t('gallery.subtitle')}>
  <section class="max-w-7xl mx-auto px-6 pt-20 pb-12">
    <p class="text-xs uppercase tracking-[0.3em] text-neutral-400 mb-4">
      {t('gallery.subtitle')}
    </p>
    <h1 class="text-5xl md:text-6xl font-light tracking-tight mb-12">
      {t('gallery.title')}
    </h1>

    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 md:gap-4 border-b border-neutral-100 pb-6">
      <button
        type="button"
        data-category="all"
        class="filter-btn text-xs uppercase tracking-[0.25em] px-4 py-2 border border-black text-black bg-black/5"
      >
        {t('gallery.allCategories')}
      </button>
      {categories.map(({ key, slug }) => (
        <button
          type="button"
          data-category={slug}
          class="filter-btn text-xs uppercase tracking-[0.25em] px-4 py-2 border border-neutral-200 text-neutral-600 hover:border-black hover:text-black transition-colors"
        >
          {t(key)}
        </button>
      ))}
    </div>
  </section>

  <!-- Gallery grid -->
  <section class="max-w-7xl mx-auto px-6 pb-32">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {Array.from({ length: 6 }).map((_, i) => (
        <div class="aspect-[4/5] bg-neutral-100 hover:bg-neutral-200 transition-colors duration-500 flex items-center justify-center">
          <span class="text-xs uppercase tracking-[0.25em] text-neutral-400">Yakında {i + 1}</span>
        </div>
      ))}
    </div>
    <p class="text-center text-sm text-neutral-400 mt-16 italic">
      {t('gallery.empty')}
    </p>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => {
        b.classList.remove('border-black', 'text-black', 'bg-black/5');
        b.classList.add('border-neutral-200', 'text-neutral-600');
      });
      btn.classList.remove('border-neutral-200', 'text-neutral-600');
      btn.classList.add('border-black', 'text-black', 'bg-black/5');
    });
  });
</script>
